#!/usr/bin/env bash
set -euo pipefail

# bin/db-shell
# Quick access to the Continuwuity results database directly via SSH or locally.

# Source .env if it exists
if [ -f ".env" ]; then
	# shellcheck disable=SC1091
	source .env
fi

SSH_TARGET=${DB_SSH_TARGET:-"git@nutra.tk"}

# If they provide a URL in .env, use it! Otherwise fallback.
DB_TARGET=${DATABASE_URL:-"postgresql://gitreadonly@127.0.0.1:5432/c10y"}

# Force nutra.tk to 127.0.0.1 because we are tunneling
DB_TARGET="${DB_TARGET//nutra.tk/127.0.0.1}"

# Mask password for safe echo
SAFE_TARGET=$(echo "$DB_TARGET" | sed 's/:[^@/]*@/:***@/')

# Automatically detect if we are already on the database server
if [[ "$(hostname 2>/dev/null || cat /etc/hostname 2>/dev/null || echo "")" == *"vps76"* ]] || [[ "$SSH_TARGET" == "local" ]]; then
	echo "→ Connecting locally using '$SAFE_TARGET'..."
	exec psql "$DB_TARGET" "$@"
else
	echo "→ Opening temporary SSH tunnel to $SSH_TARGET..."

	# Open SSH tunnel in the background using the exact default Postgres port (5432)
	ssh -f -N -M -S /tmp/c10y-db-socket -L 5432:127.0.0.1:5432 "$SSH_TARGET"

	echo "→ Connecting via local tunnel using '$SAFE_TARGET'..."

	# Run psql locally (turn off set -e so we can safely clean up the socket after)
	set +e
	if [ $# -eq 0 ]; then
		psql "$DB_TARGET"
	else
		psql "$DB_TARGET" "$@"
	fi
	EXIT_CODE=$?

	# Close and clean up the background SSH tunnel
	ssh -S /tmp/c10y-db-socket -O exit "$SSH_TARGET" 2>/dev/null

	exit $EXIT_CODE
fi
