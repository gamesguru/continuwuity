#!/usr/bin/env bash
set -euo pipefail

# bin/db-shell
# Quick access to the Continuwuity results database via SSH Tunnel.

# Default to the local tunnel entry point (port 5433)
# To start the tunnel: ssh -C -N -L 5433:127.0.0.1:5432 gg@nutra.tk
DB_TARGET=${DATABASE_URL:-"postgresql://git@localhost:5433/c10y"}

echo "→ Connecting via SSH Tunnel: $(echo "$DB_TARGET" | sed 's/:[^@]*@/:***@/')"
exec psql "$DB_TARGET" "$@"
