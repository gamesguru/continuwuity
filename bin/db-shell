#!/usr/bin/env bash
set -euo pipefail

# bin/db-shell
# Quick access to the Continuwuity results database directly via SSH or locally.

# Source .env if it exists
if [ -f ".env" ]; then
    # shellcheck disable=SC1091
    source .env
fi

SSH_TARGET=${DB_SSH_TARGET:-"git@nutra.tk"}
DB_NAME=${DB_NAME:-"c10y"}
DB_USER=${DB_USER:-"git"}

# Automatically detect if we are already on the database server
if [[ "$(hostname 2>/dev/null || cat /etc/hostname 2>/dev/null || echo "")" == *"vps76"* ]] || [[ "$SSH_TARGET" == "local" ]]; then
    echo "→ Connecting locally to $DB_NAME..."
    exec psql -U "$DB_USER" "$DB_NAME" "$@"
else
    echo "→ Connecting directly via SSH to $SSH_TARGET..."
    # Securely escape all arguments so the remote shell doesn't split the SQL query
    printf -v QUOTED_ARGS '%q ' "$@"
    exec ssh -t "$SSH_TARGET" "psql -U $DB_USER $DB_NAME $QUOTED_ARGS"
fi
