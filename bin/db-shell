#!/usr/bin/env bash
set -euo pipefail

# bin/db-shell
# Quick access to the Continuwuity results database.

# Source .env if it exists
if [ -f ".env" ]; then
    # shellcheck disable=SC1091
    source .env
fi

# Fallback to direct remote connection with sslmode=disable
DB_TARGET=${DATABASE_URL:-"postgresql://git@nutra.tk:5433/c10y?sslmode=disable"}

echo "→ Connecting: $(echo "$DB_TARGET" | sed 's/:[^@]*@/:***@/')"
exec psql "$DB_TARGET" "$@"
